{
  "openapi": "3.0.3",
  "info": {
    "title": "SSSAHAM Real-Time API",
    "version": "2026-04-03",
    "description": "Unified API documentation for endpoints consumed by the SSSAHAM frontend application."
  },
  "servers": [
    {
      "url": "https://api-saham.mkemalw.workers.dev",
      "description": "Development"
    },
    {
      "url": "https://api.sssaham.com",
      "description": "Production"
    }
  ],
  "tags": [
    {
      "name": "Docs",
      "description": "Documentation endpoints"
    },
    {
      "name": "System",
      "description": "Health and runtime utilities"
    },
    {
      "name": "Market Data",
      "description": "Screener, summary, sector, and ticker APIs"
    },
    {
      "name": "Orderflow",
      "description": "Orderflow and footprint APIs"
    },
    {
      "name": "Broker",
      "description": "Broker profile, activity, and aggregation APIs"
    },
    {
      "name": "Assets",
      "description": "Static assets such as logo/image endpoints"
    },
    {
      "name": "AI",
      "description": "AI screenshot and scoring APIs"
    },
    {
      "name": "Dashboard",
      "description": "Dashboard feed and catalyst APIs"
    }
  ],
  "components": {
    "schemas": {
      "GenericObject": {
        "type": "object",
        "additionalProperties": true
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          }
        }
      },
      "WatchlistSyncRequest": {
        "type": "object",
        "required": [
          "symbols"
        ],
        "properties": {
          "symbols": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-Z]{2,6}$"
            }
          },
          "source": {
            "type": "string",
            "example": "browser"
          },
          "ts": {
            "type": "integer",
            "format": "int64",
            "example": 1760000000000
          }
        }
      },
      "AnalyzeBroksumRequest": {
        "type": "object",
        "required": [
          "symbol"
        ],
        "properties": {
          "symbol": {
            "type": "string",
            "description": "Ticker symbol (e.g. BBRI)",
            "example": "BBRI"
          },
          "from": {
            "type": "string",
            "format": "date",
            "example": "2026-03-01"
          },
          "to": {
            "type": "string",
            "format": "date",
            "example": "2026-03-31"
          },
          "force": {
            "type": "boolean",
            "default": false
          },
          "image_keys": {
            "type": "array",
            "description": "Optional screenshot references from client side",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ClaudeScoreCandidate": {
        "type": "object",
        "required": [
          "symbol"
        ],
        "properties": {
          "symbol": {
            "type": "string",
            "example": "BBCA"
          },
          "growth_pct": {
            "type": "number"
          },
          "freq": {
            "type": "number"
          },
          "sm": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "fn": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "ln": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "flow": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "effort": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "vwap": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "ngr": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "rvol": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "cvd_multi": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "orderflow": {
            "$ref": "#/components/schemas/GenericObject"
          },
          "quadrant": {
            "type": "integer"
          },
          "state": {
            "type": "string"
          },
          "trend": {
            "$ref": "#/components/schemas/GenericObject"
          }
        }
      },
      "ClaudeScoreRequest": {
        "type": "object",
        "required": [
          "candidates"
        ],
        "properties": {
          "candidates": {
            "type": "array",
            "minItems": 10,
            "maxItems": 1000,
            "items": {
              "$ref": "#/components/schemas/ClaudeScoreCandidate"
            }
          },
          "symbols": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "filter_state": {
            "type": "object",
            "additionalProperties": true
          },
          "sort_key": {
            "type": "string"
          },
          "sort_dir": {
            "type": "string",
            "enum": [
              "asc",
              "desc",
              "ASC",
              "DESC"
            ]
          }
        }
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "Docs"
        ],
        "summary": "Redirect to API docs",
        "description": "Redirects to `/docs`.",
        "responses": {
          "302": {
            "description": "Redirect response"
          }
        }
      }
    },
    "/docs": {
      "get": {
        "tags": [
          "Docs"
        ],
        "summary": "Swagger UI documentation page",
        "description": "Interactive API docs (Swagger UI).",
        "responses": {
          "200": {
            "description": "HTML documentation page",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/console": {
      "get": {
        "tags": [
          "Docs"
        ],
        "summary": "Documentation console page",
        "description": "Alias to the interactive docs page.",
        "responses": {
          "200": {
            "description": "HTML documentation page",
